---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  /** Optional "view all" style link shown on the right. */
  linkHref?: string;
  linkLabel?: string;
}

const { eyebrow, title, description, linkHref, linkLabel } = Astro.props;
---

<div class="section-header">
  <div class="section-header__titles">
    {eyebrow && <p class="section-header__eyebrow">{eyebrow}</p>}
    <h2>{title}</h2>
    {description && <p class="section-header__desc">{description}</p>}
  </div>
  {
    linkHref && (
      <a class="section-header__link" href={linkHref}>
        {linkLabel ?? 'View all'} &rarr;
      </a>
    )
  }
</div>
