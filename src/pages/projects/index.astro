---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<BaseLayout
  title="Projects"
  description="Selected AI engineering case studies: human-in-the-loop workflows, agentic automation, and auditable systems."
>
  <div class="page-header">
    <div class="container">
      <p class="page-header__eyebrow">Selected work</p>
      <h1>Projects</h1>
      <p class="lead">
        Case studies in reliable, human-in-the-loop AI for real-world operations. Each
        writeup is abstracted and sanitized — the focus is on the engineering thinking,
        not proprietary detail.
      </p>
    </div>
  </div>

  <div class="section">
    <div class="container">
      <div class="grid grid--cards">
        {projects.map((project) => <ProjectCard project={project} />)}
      </div>
    </div>
  </div>
</BaseLayout>
