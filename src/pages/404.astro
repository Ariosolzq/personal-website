---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found" description="The page you're looking for doesn't exist.">
  <section class="hero">
    <div class="container">
      <p class="hero__eyebrow">404</p>
      <h1 class="hero__title">Page not found</h1>
      <p class="hero__positioning">
        The page you're looking for doesn't exist or has moved.
      </p>
      <div class="hero__actions">
        <a class="btn btn--primary" href="/">Back home</a>
        <a class="btn btn--ghost" href="/projects">View projects</a>
      </div>
    </div>
  </section>
</BaseLayout>
